    "@capgo/capacitor-social-login": "^8.3.17",
    "@tailwindcss/vite": "^4.2.4",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
