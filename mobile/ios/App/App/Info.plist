<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>OneRMV</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- Export compliance: app only uses HTTPS via the OS. No custom crypto.
	     Setting this to false bakes the "exempt from export compliance"
	     answer into the build so App Store Connect stops asking on every
	     upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- HealthKit read access — required so iOS shows the "OneRMV would
	     like to access your step count" prompt and lets HKHealthStore
	     return data. -->
	<key>NSMotionUsageDescription</key>
	<string>OneRMV counts your daily steps from the iPhone motion sensor when you choose "iPhone motion" as your step source, to power your personal step tracker.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>OneRMV reads your step count from Apple Health to track Stepup challenge progress. Data is sent to the community server only when you participate in an active challenge.</string>
	<!-- We don't actually write to Apple Health, but Apple's static
	     analyzer scans the linked HealthKit framework symbols and rejects
	     the upload without this key present. The string still gets shown
	     if any code path ever does request write access. -->
	<key>NSHealthUpdateUsageDescription</key>
	<string>OneRMV does not write data back to Apple Health. This permission is requested by the HealthKit framework but is never used.</string>
	<key>GIDClientID</key>
	<string>114554164765-h0ppp7e7enlkql9iebmcc0lef89bol74.apps.googleusercontent.com</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.114554164765-h0ppp7e7enlkql9iebmcc0lef89bol74</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
