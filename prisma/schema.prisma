  reason      String?        // optional context — "Won Sunday Bollywood Quiz Night"
  awardedById String
  awardedBy   Resident       @relation("MedalsAwarded", fields: [awardedById], references: [id])
  notifications Notification[]
  createdAt   DateTime       @default(now())

  @@index([recipientId])
  @@index([awardedById])
  @@index([createdAt])
}

// ─── End Medals ────────────────────────────────────────────────────────────

// ─── Public Events ─────────────────────────────────────────────────────────
// Vendor/community events (e.g. hearing check-up camp) where anyone — not
// just logged-in residents — can register with name + block + flat + phone.
// Registrations are visible only to admins for privacy; public pages show
// only event details + the registration form.

model PublicEvent {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  title                String
  description          String?  // markdown-ish body (paragraphs)
  organizer            String?  // "Amplifon India"
  venue                String?  // "Club House - RMV Clusters Phase 2"
  startAt              DateTime
  endAt                DateTime?
  registrationClosesAt DateTime?
  active               Boolean  @default(true)
  // Optional contribution/crowdsourcing config. When contributionEnabled is
  // true, the public form collects a rupee amount from each registrant and
  // the page shows payment instructions (UPI + QR). Admins mark entries paid
  // manually after receiving the money offline.
  contributionEnabled  Boolean  @default(false)
  maxContribution      Int?     // rupees; enforced on the form if set
  targetAmount         Int?     // rupees; shown as a thermometer if set
  paymentInstructions  String?  // markdown text shown near the payment details
  paymentQrImageUrl    String?  // uploaded QR (Vercel Blob URL)
  upiId                String?  // e.g. "9019903594@okbizaxis"
  // When true, the public form collects an email from each registrant
  // (useful for events that need to follow up — e.g. TestFlight invites
  // need an Apple ID email). Optional otherwise.
  requireEmail         Boolean  @default(false)
  createdById          String
  createdBy            Resident @relation("PublicEventsCreated", fields: [createdById], references: [id])
  registrations        PublicEventRegistration[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([active])
  @@index([startAt])
}

model PublicEventRegistration {
  id                 String      @id @default(cuid())
  eventId            String
  event              PublicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name               String
  phone              String
  email              String?     // optional; required when event.requireEmail is true
  block              Int?
  flatNumber         String?
  // Contribution fields — populated only on contribution-enabled events.
  contributionAmount Int?        // rupees pledged
  paid               Boolean     @default(false)
  paidAt             DateTime?
  adminNote          String?     // optional admin note when toggling paid
  createdAt          DateTime    @default(now())

  @@index([eventId])
  @@index([phone])
}

// ─── End Public Events ─────────────────────────────────────────────────────

// ─── Vehicle Stickers ──────────────────────────────────────────────────────
// One row per flat — captures how many 4-wheeler / 2-wheeler stickers each
// flat needs for the new security agency rollout (25 May 2026 onwards).
// Public form fills this; admin reconciles for printing and pickup.
//
// `block + flatNumber` is the natural unique key — if the same flat submits
// twice we upsert (latest submission wins), so totals stay correct.

model VehicleStickerRequest {
  id            String    @id @default(cuid())
  block         Int
  flatNumber    String
  residentName  String
  phone         String
  email         String?
  residentType  String    // "OWNER" | "TENANT"
  fourWheelers  Int       @default(0)
  twoWheelers   Int       @default(0)
  notes         String?
  // Self-declared compliance flags. Set true by the resident on the form;
  // admin can override via the dashboard.
  mygateRegistered    Boolean @default(false) // resident confirms MyGate has vehicle details
  alreadyHasSticker   Boolean @default(false) // resident already collected somehow
  // Pickup tracking — set by admin once stickers are handed over, OR auto-set
  // when alreadyHasSticker=true with issuedBy="self-declared".
  stickersIssued Boolean  @default(false)
  issuedAt       DateTime?
  issuedBy       String?  // admin name, or "self-declared" for auto-issued rows
  adminNote      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([block, flatNumber], name: "block_flat")
  @@index([stickersIssued])
  @@index([mygateRegistered])
}

// ─── End Vehicle Stickers ──────────────────────────────────────────────────

// ─── Push Notification Device Tokens ───────────────────────────────────────

// Per-resident push tokens. Each resident may have several rows — one per
// device they sign in on. The token itself is unique across all rows so we
// can de-dupe when the same device is reused. `platform` is currently
// always "ios" but is here so we can fan out to Android/web later without
// a schema change.
model DeviceToken {
  id          String   @id @default(cuid())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  token       String   @unique
  platform    String   // "ios" | "android" | "web"
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([residentId])
}

// ─── End Push Notification Device Tokens ───────────────────────────────────
