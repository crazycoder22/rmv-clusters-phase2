enum TambolaSessionStatus {
  WAITING
  ACTIVE
  COMPLETED
}

enum TambolaPrizeType {
  EARLY_FIVE
  TOP_LINE
  MIDDLE_LINE
  BOTTOM_LINE
  FULL_HOUSE
}

model TambolaSession {
