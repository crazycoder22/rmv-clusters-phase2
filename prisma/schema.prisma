generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        String     @id @default(cuid())
  name      String     @unique // "RESIDENT", "ADMIN", "SUPERADMIN", "SECURITY", "FACILITY_MANAGER", "EVENT_MANAGER", "COMMUNITY_ADMIN"
  residents Resident[]
  createdAt DateTime   @default(now())
}

model Flat {
  id          String    @id @default(cuid())
  block       Int       // 1, 2, 3, or 4
  flatNumber  String    // e.g., "001/002", "103"
  isBankOwned Boolean   @default(false) // bank-owned (always tenant-occupied) — source of truth
  vehicles    Vehicle[]

  @@unique([block, flatNumber])
  @@index([block])
}

model Vehicle {
  id            String   @id @default(cuid())
  vehicleNumber String   // e.g., "KA04MT2711"
  vehicleType   String   // "Car", "Two Wheeler"
  isEV          Boolean  @default(false)
  parkingName   String?  // e.g., "2-109"
  block         Int
  flatNumber    String
  flat          Flat?    @relation(fields: [block, flatNumber], references: [block, flatNumber])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([vehicleNumber])
  @@index([block, flatNumber])
}

model Announcement {
  id          String       @id @default(cuid())
  title       String
  date        DateTime     @default(now())
  category    String       // "maintenance", "event", "general", "urgent"
  priority    String       @default("normal") // "low", "normal", "high"
  summary     String
  body        String
  author      String
  link        String?
  linkText    String?
  published   Boolean      @default(true)
  emoji       String?
  imageUrl    String?
  eventConfig   EventConfig?
  sportsConfig  SportsConfig?
  notifications Notification[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Resident {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String
  block        Int      // 1, 2, 3, or 4
  flatNumber   String   // e.g., "101", "G2"
  residentType String   // "OWNER" | "OWNER_FAMILY" | "TENANT" | "TENANT_FAMILY" | "MULTI_TENANT"
  isApproved   Boolean  @default(false)
  isSosWarrior Boolean  @default(false)
  isSeniorCitizen Boolean @default(false)
  dailyStepGoal Int      @default(0) // 0 = no personal step goal set
  stepSource   String?  // chosen step source: "apple_health" | "core_motion" | "health_connect"
  deactivatedAt DateTime? // set when a SUPERADMIN deactivates the account; blocks all access. null = active.
  // Usage tracking — stamped (throttled) on authenticated API calls.
  lastSeenAt   DateTime? // last authenticated activity
  lastPlatform String?   // "web" | "ios" | "android" | "app"
  googleImage  String?
  roles        Role[]
  rsvps                Rsvp[]
  eventFeedbacks       EventFeedback[]
  sportsRegistrations  SportsRegistration[]
  notifications        Notification[]
  issues               Issue[]
  closedIssues         Issue[]  @relation("ClosedIssues")
  tasksCreated             Task[]   @relation("TasksCreated")
  tasksOwned               Task[]   @relation("TasksOwned")
  taskComments             TaskComment[]
  checklistEntries         ChecklistEntry[]
  newsletterSubmissions    NewsletterSubmission[]
  posts                    Post[]
  postComments             PostComment[]
  postLikes                PostLike[]
  medalsReceived           MedalAward[]  @relation("MedalsReceived")
  medalsAwarded            MedalAward[]  @relation("MedalsAwarded")
  publicEventsCreated      PublicEvent[] @relation("PublicEventsCreated")
  meetingsCreated          Meeting[]        @relation("MeetingsCreated")
  meetingRsvps             MeetingRsvp[]
  reviewDocuments          ReviewDocument[]
  reviewComments           ReviewComment[]
  resolvedReviewComments   ReviewComment[] @relation("ResolvedComments")
  hkFeedbacks              HKFeedback[]
  surveysCreated           Survey[]        @relation("SurveysCreated")
  pollsCreated             Poll[]          @relation("PollsCreated")
  pollVotes                PollVote[]
  domesticHelpAdded        DomesticHelp[]       @relation("DomesticHelpAdded")
  domesticHelpReviews      DomesticHelpReview[] @relation("DomesticHelpReviews")
  foodVendorsAdded         FoodVendor[]         @relation("FoodVendorsAdded")
  marketplaceListings      MarketplaceListing[]               @relation("MarketplaceListings")
  marketplaceWishlist      MarketplaceWishlist[]               @relation("MarketplaceWishlist")
  marketplaceCategorySubs  MarketplaceCategorySubscription[]   @relation("MarketplaceCategorySubscriptions")
  tambolaSessions          TambolaSession[]
  quizzes                  Quiz[]
  quizSessionsCreated      QuizSession[]    @relation("QuizSessionsCreated")
  deviceTokens             DeviceToken[]
  habitsOwned              Habit[]          @relation("HabitsOwned")
  habitsPartnered          Habit[]          @relation("HabitsPartnered")
  foodMenusByChef          FoodMenu[]       @relation("FoodMenusByChef")
  foodOrdersByBuyer        FoodOrder[]      @relation("FoodOrdersByBuyer")
  foodMenusCoManaged       FoodMenuManager[] @relation("FoodMenuCoManaged")
  chefFollowers            ChefFollow[]     @relation("ChefFollowers")
  chefFollowing            ChefFollow[]     @relation("ChefFollowing")
  parkingSlotsOwned     ParkingSlot[]    @relation("ParkingSlotsOwned")
  parkingBookings       ParkingBooking[] @relation("ParkingBookingsByBooker")
  initiativesAuthored      Initiative[]            @relation("InitiativesAuthored")
  initiativeComments       InitiativeComment[]     @relation("InitiativeCommentsAuthored")
  initiativeCommentLikes   InitiativeCommentLike[] @relation("InitiativeCommentLikes")
  referendumsAuthored      Referendum[]            @relation("ReferendumsAuthored")
  referendumBallots        ReferendumBallot[]      @relation("ReferendumBallotsCast")
  dutyChecklistsCreated    DutyChecklist[]         @relation("DutyChecklistsCreated")
  dutyChecklistsOwned      DutyChecklistOwner[]    @relation("DutyChecklistsOwned")
  dutyCompletions          DutyCompletion[]        @relation("DutyCompletions")
  conversationsA           Conversation[]          @relation("ConvA")
  conversationsB           Conversation[]          @relation("ConvB")
  messagesSent             DirectMessage[]         @relation("MessagesSent")
  groupsCreated            Group[]                 @relation("GroupsCreated")
  groupMemberships         GroupMember[]           @relation("GroupMemberships")
  groupPollsAuthored       GroupPoll[]             @relation("GroupPollsAuthored")
  groupPollVotes           GroupPollVote[]         @relation("GroupPollVotes")
  sosAlertsSent            SosAlert[]              @relation("SosAlertsSent")
  sosResponses             SosResponse[]           @relation("SosResponses")
  amenityBookings          AmenityBooking[]        @relation("AmenityBookingsByBooker")
  dailySteps               ResidentDailySteps[]
  stepChallengePartnerOf   StepChallengeGoal[]     @relation("StepChallengePartner")
  pageViews                PageView[]              @relation("PageViews")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// Always-on personal step tracking (independent of step-challenge events).
// One row per resident per calendar day; `source` records where the count came
// from. Mirrors StepEntry's "midnight-UTC date" convention.
model ResidentDailySteps {
  id         String   @id @default(cuid())
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  date       DateTime // midnight UTC of the entry's day
  steps      Int
  source     String   // "apple_health" | "core_motion" | "health_connect" | "manual"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([residentId, date])
  @@index([residentId, date])
}

// Generic page/feature view log — powers the admin "Page views" dashboard.
// One row per resident per page per ~viewing-session (the write helper dedups
// repeat opens within a 30-min window). `feature`/`pageKey` are server-whitelisted
// strings (not enums) so a new page is a one-line whitelist edit, no migration.
// Aggregate-only: the admin API never exposes who viewed what, just counts.
model PageView {
  id         String   @id @default(cuid())
  residentId String
  resident   Resident @relation("PageViews", fields: [residentId], references: [id], onDelete: Cascade)
  feature    String   // e.g. "initiatives"
  pageKey    String   // "list" | "detail"
  entityId   String?  // specific item id on detail pages; null on list pages
  platform   String   // "web" | "ios" | "android" | "app"
  durationMs Int?     // dwell time on the page (visible ms), filled in on leave/background
  createdAt  DateTime @default(now())

  @@index([feature, pageKey, entityId, createdAt])              // rollups + trend
  @@index([feature, pageKey, entityId, residentId])             // unique-resident counts
  @@index([residentId, feature, pageKey, entityId, createdAt])  // dedup guard lookup
  @@map("page_views")
}

model EventConfig {
  id             String       @id @default(cuid())
  announcementId String       @unique
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  mealType        String?      // "breakfast", "lunch", "dinner" (optional for non-food events)
  rsvpDeadline    DateTime
  requirePayment   Boolean      @default(false)
  entranceFee      Float?       // null = no fee; > 0 = amount in INR
  entranceFeeLabel String       @default("Entrance Fee")
  confirmationMessage String?    // Optional message shown after RSVP (e.g., group link)
  enableFeedback   Boolean      @default(false)
  feedbackStyle   String       @default("stars") // "stars" or "emoji"
  // When true, mobile app surfaces a step-tracking dashboard for participants
  // and the /api/me/step-events endpoint lists this event. Stepup challenges
  // toggle this on; food/RSVP-only events leave it off.
  stepTrackingEnabled Boolean   @default(false)
  menuItems      MenuItem[]
  customFields   CustomField[]
  challengeGoals StepChallengeGoal[]
  rsvps          Rsvp[]
  guestRsvps     GuestRsvp[]
  feedbacks      EventFeedback[]
  stepEntries    StepEntry[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MenuItem {
  id            String      @id @default(cuid())
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)
  name          String
  pricePerPlate Float
  sortOrder     Int         @default(0)
  rsvpItems      RsvpItem[]
  guestRsvpItems GuestRsvpItem[]
  createdAt      DateTime    @default(now())
}

model Rsvp {
  id            String      @id @default(cuid())
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)
  residentId    String
  resident      Resident    @relation(fields: [residentId], references: [id], onDelete: Cascade)
  items          RsvpItem[]
  fieldResponses RsvpFieldResponse[]
  paid              Boolean     @default(false)
  razorpayOrderId   String?
  razorpayPaymentId String?
  attended       Boolean     @default(false)
  attendedAt     DateTime?
  notes          String?
  stepEntries    StepEntry[]
  challengeGoal  StepChallengeGoal?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([eventConfigId, residentId])
}

// Per-participant extras for a step-challenge event (Mini Step-Up style):
// optional 5K/10K/20K run goals + self-declared completions, and an optional
// accountability partner (invite/accept flow mirrors Habits). The daily step
// goal itself stays in a CustomField/RsvpFieldResponse (parseGoal); this model
// only holds the genuinely-new run + partner data. 1:1 with an Rsvp.
enum StepPartnerStatus {
  none
  pending
  accepted
  declined
}

model StepChallengeGoal {
  id            String            @id @default(cuid())
  eventConfigId String
  eventConfig   EventConfig       @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)
  rsvpId        String            @unique
  rsvp          Rsvp              @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  run5kGoal     Int               @default(0)
  run10kGoal    Int               @default(0)
  run20kGoal    Int               @default(0)
  run5kDone     Int               @default(0)
  run10kDone    Int               @default(0)
  run20kDone    Int               @default(0)
  partnerId     String?
  partner       Resident?         @relation("StepChallengePartner", fields: [partnerId], references: [id])
  partnerStatus StepPartnerStatus @default(none)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([eventConfigId])
  @@index([partnerId])
}

model RsvpItem {
  id         String   @id @default(cuid())
  rsvpId     String
  rsvp       Rsvp     @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  plates     Int
  createdAt  DateTime @default(now())

  @@unique([rsvpId, menuItemId])
}

model GuestRsvp {
  id            String          @id @default(cuid())
  eventConfigId String
  eventConfig   EventConfig     @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)
  name          String
  email         String
  phone         String
  block         Int
  flatNumber    String
  items          GuestRsvpItem[]
  fieldResponses GuestRsvpFieldResponse[]
  paid              Boolean         @default(false)
  razorpayOrderId   String?
  razorpayPaymentId String?
  attended       Boolean         @default(false)
  attendedAt     DateTime?
  notes          String?
  stepEntries    StepEntry[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([eventConfigId, email])
}

model GuestRsvpItem {
  id          String    @id @default(cuid())
  guestRsvpId String
  guestRsvp   GuestRsvp @relation(fields: [guestRsvpId], references: [id], onDelete: Cascade)
  menuItemId  String
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  plates      Int
  createdAt   DateTime  @default(now())

  @@unique([guestRsvpId, menuItemId])
}

model CustomField {
  id            String      @id @default(cuid())
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)
  label         String
  fieldType     String      // "text" or "select"
  required      Boolean     @default(false)
  options       String?     // JSON array string for "select" type, e.g. '["Option A","Option B"]'
  sortOrder     Int         @default(0)

  rsvpFieldResponses      RsvpFieldResponse[]
  guestRsvpFieldResponses GuestRsvpFieldResponse[]

  createdAt DateTime @default(now())
}

model RsvpFieldResponse {
  id            String      @id @default(cuid())
  rsvpId        String
  rsvp          Rsvp        @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  value         String

  createdAt DateTime @default(now())

  @@unique([rsvpId, customFieldId])
}

model GuestRsvpFieldResponse {
  id            String      @id @default(cuid())
  guestRsvpId   String
  guestRsvp     GuestRsvp   @relation(fields: [guestRsvpId], references: [id], onDelete: Cascade)
  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  value         String

  createdAt DateTime @default(now())

  @@unique([guestRsvpId, customFieldId])
}

model EventFeedback {
  id            String      @id @default(cuid())
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)
  residentId    String?
  resident      Resident?   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  deviceId      String      // Browser-generated unique device ID for one-per-device enforcement
  rating        Int         // 1-5
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([eventConfigId, deviceId])
}

model SportsConfig {
  id                   String               @id @default(cuid())
  announcementId       String               @unique
  announcement         Announcement         @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  registrationDeadline DateTime
  sportItems           SportItem[]
  registrations        SportsRegistration[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model SportItem {
  id               String             @id @default(cuid())
  sportsConfigId   String
  sportsConfig     SportsConfig       @relation(fields: [sportsConfigId], references: [id], onDelete: Cascade)
  name             String
  sortOrder        Int                @default(0)
  participantSports ParticipantSport[]
  createdAt        DateTime           @default(now())
}

model SportsRegistration {
  id             String       @id @default(cuid())
  sportsConfigId String
  sportsConfig   SportsConfig @relation(fields: [sportsConfigId], references: [id], onDelete: Cascade)
  residentId     String
  resident       Resident     @relation(fields: [residentId], references: [id], onDelete: Cascade)
  participants   Participant[]
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([sportsConfigId, residentId])
}

model Participant {
  id                   String             @id @default(cuid())
  sportsRegistrationId String
  sportsRegistration   SportsRegistration @relation(fields: [sportsRegistrationId], references: [id], onDelete: Cascade)
  name                 String
  ageCategory          String             // "kid", "teen", "adult"
  sports               ParticipantSport[]
  createdAt            DateTime           @default(now())
}

model ParticipantSport {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  sportItemId   String
  sportItem     SportItem   @relation(fields: [sportItemId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([participantId, sportItemId])
}

model Visitor {
  id            String         @id @default(cuid())
  name          String
  phone         String?
  email         String?
  vehicleNumber String?
  visitingBlock Int
  visitingFlat  String
  status        String         @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Notification {
  id             String        @id @default(cuid())
  residentId     String
  resident       Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  announcementId String?
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  visitorId      String?
  visitor        Visitor?      @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  issueId        String?
  issue          Issue?        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  taskId         String?
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  postId         String?
  post           Post?         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reviewDocId    String?
  reviewDoc      ReviewDocument? @relation(fields: [reviewDocId], references: [id], onDelete: Cascade)
  pollId         String?
  poll           Poll?          @relation(fields: [pollId], references: [id], onDelete: Cascade)
  surveyId       String?
  survey         Survey?        @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  marketplaceListingId String?
  marketplaceListing   MarketplaceListing? @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)
  medalAwardId   String?
  medalAward     MedalAward?   @relation(fields: [medalAwardId], references: [id], onDelete: SetNull)
  message        String?
  read           Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@unique([residentId, announcementId])
  @@index([residentId, read])
  @@index([visitorId])
  @@index([issueId])
  @@index([taskId])
  @@index([postId])
  @@index([reviewDocId])
  @@index([pollId])
  @@index([surveyId])
  @@index([marketplaceListingId])
  @@index([medalAwardId])
}

model Issue {
  id               String    @id @default(cuid())
  title            String
  description      String
  category         String    // "ELECTRICAL", "PLUMBING", "OTHER"
  status           String    @default("OPEN") // "OPEN", "CLOSED"
  residentId       String
  resident         Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  closedBy         String?
  closedByResident Resident? @relation("ClosedIssues", fields: [closedBy], references: [id])
  closureComment   String?
  closedAt         DateTime?
  notifications    Notification[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([residentId])
  @@index([status])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String
  category    String    // "MAINTENANCE", "ELECTRICAL", "PLUMBING", "SECURITY", "GENERAL"
  priority    String    @default("NORMAL") // "LOW", "NORMAL", "HIGH", "URGENT"
  status      String    @default("OPEN")   // "OPEN", "IN_PROGRESS", "ON_HOLD", "BLOCKED", "CLOSED"
  deadline    DateTime

  createdById String
  createdBy   Resident  @relation("TasksCreated", fields: [createdById], references: [id])

  ownerId     String
  owner       Resident  @relation("TasksOwned", fields: [ownerId], references: [id])

  closedAt    DateTime?

  comments      TaskComment[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([createdById])
  @@index([status])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    Resident @relation(fields: [authorId], references: [id])
  content   String
  oldStatus String?
  newStatus String?
  createdAt DateTime @default(now())

  @@index([taskId])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  color     String   @default("#3b82f6")
  emoji     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StepEntry {
  id            String      @id @default(cuid())
  eventConfigId String
  eventConfig   EventConfig @relation(fields: [eventConfigId], references: [id], onDelete: Cascade)
  rsvpId        String?
  rsvp          Rsvp?       @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  guestRsvpId   String?
  guestRsvp     GuestRsvp?  @relation(fields: [guestRsvpId], references: [id], onDelete: Cascade)
  date          DateTime
  steps         Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([rsvpId, date])
  @@unique([guestRsvpId, date])
  @@index([eventConfigId, date])
}

model ExpenseMonth {
  id        String        @id @default(cuid())
  month     Int           // 1-12
  year      Int           // e.g., 2026
  notes     String?
  items     ExpenseItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([month, year])
  @@index([year, month])
}

model ExpenseItem {
  id               String       @id @default(cuid())
  expenseMonthId   String
  expenseMonth     ExpenseMonth @relation(fields: [expenseMonthId], references: [id], onDelete: Cascade)
  description      String
  totalAmount      Float
  distributionType String       // "percentage" | "block_specific" | "custom" | "income"
  targetBlock      Int?         // For block_specific: which block (1-4)
  block1Amount     Float        @default(0)
  block2Amount     Float        @default(0)
  block3Amount     Float        @default(0)
  block4Amount     Float        @default(0)
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([expenseMonthId])
}

model Newsletter {
  id          String              @id @default(cuid())
  title       String
  edition     String?
  coverHtml   String?             // Editor's note / intro (rich HTML)
  status      String              @default("draft") // "draft" | "published"
  publishedAt DateTime?
  sections    NewsletterSection[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
}

model NewsletterSection {
  id           String     @id @default(cuid())
  newsletterId String
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  type         String     // "news" | "article" | "ad" | "events"
  title        String
  contentHtml  String     // Rich text HTML from TipTap
  authorName   String?
  authorBlock  Int?
  authorFlat   String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([newsletterId])
}

model NewsletterSubmission {
  id          String   @id @default(cuid())
  title       String
  contentHtml String
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // "pending" | "approved" | "rejected"
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Post {
  id            String        @id @default(cuid())
  content       String
  images        String[]      // Vercel Blob URLs
  videoUrl      String?       // YouTube URL
  authorId      String
  author        Resident      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      PostComment[]
  likes         PostLike[]
  notifications Notification[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([authorId])
  @@index([createdAt])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    Resident @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
}

model PostLike {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([postId, residentId])
  @@index([postId])
}

model ChecklistItem {
  id        String           @id @default(cuid())
  name      String
  sortOrder Int              @default(0)
  active    Boolean          @default(true)
  entries   ChecklistEntry[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ChecklistEntry {
  id         String        @id @default(cuid())
  date       DateTime      @db.Date
  done       Boolean
  itemId     String
  item       ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  filledById String
  filledBy   Resident      @relation(fields: [filledById], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([date, itemId])
  @@index([itemId])
  @@index([date])
}

// ─── Housekeeping ─────────────────────────────────────────────────────────────

enum HKStaffType {
  HOUSEKEEPING
  PLUMBER
  ELECTRICIAN
  HELPER
}

model HKStaff {
  id          String         @id @default(cuid())
  name        String
  type        HKStaffType    @default(HOUSEKEEPING)
  active      Boolean        @default(true)
  assignments HKAssignment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model HKAssignment {
  id        String   @id @default(cuid())
  staffId   String
  staff     HKStaff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  block     Int      // 1–4
  month     Int      // 1–12
  year      Int
  createdAt DateTime @default(now())

  @@unique([staffId, block, month, year])
  @@index([block, month, year])
}

model HKFeedback {
  id         String    @id @default(cuid())
  block      Int
  month      Int
  year       Int
  // Logged-in resident
  residentId String?
  resident   Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)
  // Guest (non-logged-in)
  guestName  String?
  guestEmail String?
  guestPhone String?
  guestFlat  String?
  rating     Int       // 1–5
  comment    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([block, month, year])
  @@index([residentId])
}

// ─── End Housekeeping ─────────────────────────────────────────────────────────

model SosAcceptance {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  block      Int
  flatNumber String
  residentId String?  // Set if the user was logged in at the time
  createdAt  DateTime @default(now())

  @@unique([email])
  @@index([block, flatNumber])
}

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  DocumentFolder[] @relation("FolderTree")
  files     DocumentFile[]
  driveUrl  String?          // Optional Google Drive folder link
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([parentId])
}

model DocumentFile {
  id        String         @id @default(cuid())
  name      String
  folderId  String
  folder    DocumentFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  driveUrl  String?        // Google Drive file link
  fileUrl   String?        // Direct upload URL (Vercel Blob) — for future use
  fileType  String?        // e.g., "pdf", "xlsx", "image"
  fileSize  Int?           // Size in bytes
  sortOrder Int            @default(0)
  meetings       MeetingDocument[]
  reviewDocuments ReviewDocument[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([folderId])
}

model Meeting {
  id          String            @id @default(cuid())
  title       String
  agenda      String
  date        DateTime
  location    String
  status      String            @default("SCHEDULED") // "SCHEDULED", "COMPLETED", "CANCELLED"
  isPublic    Boolean           @default(false)
  momUrl      String?           // Google Drive link for Minutes of Meeting
  momSummary  String?           // Brief text summary of MOM
  creatorId   String
  creator     Resident          @relation("MeetingsCreated", fields: [creatorId], references: [id])
  rsvps       MeetingRsvp[]
  documents   MeetingDocument[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([date])
  @@index([status])
  @@index([creatorId])
}

model MeetingRsvp {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  status     String   @default("ATTENDING") // "ATTENDING", "DECLINED", "MAYBE"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([meetingId, residentId])
  @@index([meetingId])
}

model MeetingDocument {
  id         String       @id @default(cuid())
  meetingId  String
  meeting    Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  documentId String
  document   DocumentFile @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([meetingId, documentId])
  @@index([meetingId])
  @@index([documentId])
}

model ReviewDocument {
  id               String           @id @default(cuid())
  title            String
  content          String           // Tiptap JSON string
  status           String           @default("DRAFT") // "DRAFT", "PUBLISHED", "CLOSED"
  createdById      String
  createdBy        Resident         @relation(fields: [createdById], references: [id])
  linkedDocumentId String?
  linkedDocument   DocumentFile?    @relation(fields: [linkedDocumentId], references: [id], onDelete: SetNull)
  publishedAt      DateTime?
  closedAt         DateTime?
  comments         ReviewComment[]
  notifications    Notification[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
  @@index([createdById])
}

// ─── Fantasy League ────────────────────────────────────────────────────────

model FantasyMatch {
  id        String          @id @default(cuid())
  title     String          // e.g. "RCB vs CSK – IPL 2026"
  opponent  String          // e.g. "CSK"
  venue     String?
  matchDate DateTime
  status    String          @default("OPEN") // OPEN | LOCKED | COMPLETED
  players   FantasyPlayer[]
  teams     FantasyTeam[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
  @@index([matchDate])
}

model FantasyPlayer {
  id         String             @id @default(cuid())
  matchId    String
  match      FantasyMatch       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  name       String
  role       String             // BATSMAN | BOWLER | ALLROUNDER | WICKETKEEPER
  teamSlots  FantasyTeamPlayer[]
  scoreEvent FantasyScoreEvent?
  createdAt  DateTime           @default(now())

  @@index([matchId])
}

model FantasyTeam {
  id         String              @id @default(cuid())
  matchId    String
  match      FantasyMatch        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String
  block      String
  flatNumber String
  frozen     Boolean             @default(false)
  players    FantasyTeamPlayer[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([matchId, phone])
  @@index([matchId])
}

model FantasyTeamPlayer {
  id            String        @id @default(cuid())
  teamId        String
  team          FantasyTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId      String
  player        FantasyPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  isCaptain     Boolean       @default(false)
  isViceCaptain Boolean       @default(false)

  @@unique([teamId, playerId])
  @@index([teamId])
}

model FantasyScoreEvent {
  id        String        @id @default(cuid())
  playerId  String        @unique
  player    FantasyPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  runs      Int           @default(0)
  wickets   Int           @default(0)
  catches   Int           @default(0)
  runOuts   Int           @default(0)
  stumpings Int           @default(0)
  updatedAt DateTime      @updatedAt
}

// ─── End Fantasy League ───────────────────────────────────────────────────

// ─── Polls & Surveys ──────────────────────────────────────────────────────

model Survey {
  id            String         @id @default(cuid())
  title         String
  description   String?
  deadline      DateTime
  isAnonymous   Boolean        @default(false)
  status        String         @default("ACTIVE") // "ACTIVE" or "CLOSED"
  createdById   String
  createdBy     Resident       @relation("SurveysCreated", fields: [createdById], references: [id])
  polls         Poll[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([deadline])
  @@index([createdById])
}

model Poll {
  id            String         @id @default(cuid())
  title         String
  description   String?
  type          String         @default("SINGLE") // "SINGLE" or "MULTIPLE"
  isAnonymous   Boolean        @default(false)
  deadline      DateTime
  status        String         @default("ACTIVE") // "ACTIVE" or "CLOSED"
  sortOrder     Int            @default(0)
  createdById   String
  createdBy     Resident       @relation("PollsCreated", fields: [createdById], references: [id])
  surveyId      String?
  survey        Survey?        @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  options       PollOption[]
  votes         PollVote[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([deadline])
  @@index([createdById])
  @@index([surveyId])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int        @default(0)
  votes     PollVote[]
  createdAt DateTime   @default(now())

  @@index([pollId])
}

model PollVote {
  id           String     @id @default(cuid())
  pollId       String
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  residentId   String?
  resident     Resident?  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  // Guest fields (when submitted without login)
  guestName    String?
  guestEmail   String?
  guestBlock   Int?
  guestFlat    String?
  guestPhone   String?
  createdAt    DateTime   @default(now())

  @@unique([pollId, pollOptionId, residentId])
  @@index([pollId])
  @@index([residentId])
  @@index([guestEmail])
}

// ─── End Polls & Surveys ──────────────────────────────────────────────────

// ─── Domestic Help Directory ──────────────────────────────────────────────

model DomesticHelp {
