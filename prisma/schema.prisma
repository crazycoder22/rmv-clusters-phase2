  notifications   Notification[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([sellerId])
  @@index([category])
  @@index([listingType])
  @@index([status])
  @@index([createdAt])
}

model MarketplaceWishlist {
  id         String             @id @default(cuid())
  listingId  String
  listing    MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident           @relation("MarketplaceWishlist", fields: [residentId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())

  @@unique([listingId, residentId])
  @@index([listingId])
  @@index([residentId])
}

model MarketplaceCategorySubscription {
  id         String   @id @default(cuid())
  residentId String
  resident   Resident @relation("MarketplaceCategorySubscriptions", fields: [residentId], references: [id], onDelete: Cascade)
  category   String
  createdAt  DateTime @default(now())

  @@unique([residentId, category])
  @@index([category])
}

// ─── End Marketplace ──────────────────────────────────────────────────────

// ─── Wordle Game ──────────────────────────────────────────────────────────

model WordlePlayer {
  id         String       @id @default(cuid())
  name       String
  block      Int
  flatNumber String
  email      String       @unique
  phone      String
  games          WordleGame[]
  sudokuGames    SudokuGame[]
  crosswordGames CrosswordGame[]
  tambolaTickets TambolaTicket[]
  tambolaPrizes  TambolaPrize[]
  quizPlayers    QuizPlayer[]
  memoryGames    MemoryGame[]
  memoryMultiCreated MemoryMultiSession[] @relation("MemoryMultiCreated")
  memoryMultiPlayers MemoryMultiPlayer[]  @relation("MemoryMultiPlayers")
  game2048Runs   Game2048Run[]
  anagramGames   AnagramGame[]
  createdAt   DateTime     @default(now())
}

model WordleGame {
  id        String       @id @default(cuid())
  playerId  String
  player    WordlePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date      String       // YYYY-MM-DD in IST
  won       Boolean      @default(false)
  attempts  Int          @default(0) // number of guesses used (1-6)
  guesses   String       @default("[]") // JSON array of guesses
  completed Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([playerId, date])
  @@index([playerId])
  @@index([date])
}

// ─── End Wordle Game ──────────────────────────────────────────────────────

// ─── Anagram (Spelling Bee–style daily) ──────────────────────────────────
// Each player has at most one game row per IST date. The puzzle (letters +
// required) is deterministic from the date, so it's not stored on the row;
// `letters` is denormalised to keep the API simple. `foundWords` is the
// running list of accepted words (lowercase) for that day's run.

model AnagramGame {
  id          String       @id @default(cuid())
  playerId    String
  player      WordlePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date        String       // YYYY-MM-DD in IST
  letters     String       // 7 distinct letters (lowercase)
  required    String       // single letter (lowercase)
  foundWords  String       @default("[]") // JSON array of lowercase words
  score       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([playerId, date])
  @@index([date])
  @@index([playerId])
}

// ─── End Anagram ──────────────────────────────────────────────────────────

model ReviewComment {
  id               String          @id @default(cuid())
  reviewDocumentId String
  reviewDocument   ReviewDocument  @relation(fields: [reviewDocumentId], references: [id], onDelete: Cascade)
  residentId       String
  resident         Resident        @relation(fields: [residentId], references: [id])
  content          String
  type             String          @default("COMMENT") // "COMMENT" or "SUGGESTION"
  suggestedText    String?
  highlightFrom    Int?            // ProseMirror position start (null for general comments)
  highlightTo      Int?            // ProseMirror position end
  highlightedText  String?         // Snapshot of selected text
  parentId         String?
  parent           ReviewComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies          ReviewComment[] @relation("CommentThread")
  resolved         Boolean         @default(false)
  resolvedById     String?
  resolvedBy       Resident?       @relation("ResolvedComments", fields: [resolvedById], references: [id])
  resolvedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([reviewDocumentId])
  @@index([parentId])
}

// ─── Sudoku Game ──────────────────────────────────────────────────────────────

model SudokuGame {
  id          String       @id @default(cuid())
  playerId    String
  player      WordlePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date        String       // YYYY-MM-DD in IST
  difficulty  String       // "easy" | "medium" | "hard"
  puzzle      String       // JSON: number[81] with 0 for blanks
  solution    String       // JSON: number[81] complete solution
  currentGrid String       // JSON: number[81] player's live progress
  completed   Boolean      @default(false)
  timeSeconds Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([playerId, date, difficulty])
  @@index([date, difficulty])
}

// ─── End Sudoku Game ─────────────────────────────────────────────────────────

// ─── Crossword Game ──────────────────────────────────────────────────────────

model CrosswordGame {
  id          String       @id @default(cuid())
  playerId    String
  player      WordlePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date        String       // YYYY-MM-DD in IST
  puzzle      String       // JSON: clues + cellNumbers + grid template
  solution    String       // JSON: 5×5 solved grid
  currentGrid String       // JSON: 5×5 player progress
  completed   Boolean      @default(false)
  timeSeconds Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([playerId, date])
  @@index([date])
}

// ─── End Crossword Game ──────────────────────────────────────────────────────

// ─── Memory Game ────────────────────────────────────────────────────────────

model MemoryGame {
  id          String       @id @default(cuid())
  playerId    String
  player      WordlePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date        String       // YYYY-MM-DD in IST
  difficulty  String       // "easy" (4x3=6 pairs) | "medium" (4x4=8 pairs) | "hard" (5x4=10 pairs)
  moves       Int          @default(0)
  completed   Boolean      @default(false)
  timeSeconds Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([playerId, date, difficulty])
  @@index([date, difficulty])
}

// ─── Multi-player Memory Game ──────────────────────────────────────────────

enum MemoryMultiStatus {
  WAITING
  ACTIVE
  COMPLETED
}

model MemoryMultiSession {
  id             String              @id @default(cuid())
  code           String              @unique
  difficulty     String              // "easy" | "medium" | "hard"
  cards          String              // JSON array of emoji strings (fixed layout)
  matched        String              @default("[]") // JSON array of matched card indices
  flipA          Int?                // index of first flipped card in current turn
  flipB          Int?                // index of second flipped card (awaiting resolve)
  currentTurn    Int                 @default(0) // index into players ordered by joinOrder
  status         MemoryMultiStatus   @default(WAITING)
  createdById    String
  createdBy      WordlePlayer        @relation("MemoryMultiCreated", fields: [createdById], references: [id])
  players        MemoryMultiPlayer[]
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MemoryMultiPlayer {
  id         String             @id @default(cuid())
  sessionId  String
  session    MemoryMultiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId   String
  player     WordlePlayer       @relation("MemoryMultiPlayers", fields: [playerId], references: [id])
  joinOrder  Int
  matches    Int                @default(0)
  createdAt  DateTime           @default(now())

  @@unique([sessionId, playerId])
  @@index([sessionId])
}

// ─── End Memory Game ────────────────────────────────────────────────────────

// ─── 2048 ──────────────────────────────────────────────────────────────────

model Game2048Run {
  id          String       @id @default(cuid())
  playerId    String
  player      WordlePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  score       Int
  highestTile Int          // 2, 4, 8, ..., 2048, 4096, ...
  moves       Int
  duration    Int          // seconds
  won         Boolean      @default(false) // reached 2048
  createdAt   DateTime     @default(now())

  @@index([playerId])
  @@index([score])
  @@index([createdAt])
}

// ─── End 2048 ──────────────────────────────────────────────────────────────

// ─── Video Library ────────────────────────────────────────────────────────────

enum VideoCategory {
  LEARNING
  TURNING_POINT
  EVENTS
  ANNOUNCEMENTS
}

model VideoPlaylist {
  id          String        @id @default(cuid())
  name        String        // e.g. "Turning Point", "MyGate Onboarding"
  description String?
  category    VideoCategory
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  videos      Video[]
}

model Video {
  id          String         @id @default(cuid())
  title       String
  description String?
  youtubeUrl  String
  playlistId  String
  playlist    VideoPlaylist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  featured    Boolean        @default(false)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([playlistId])
}

