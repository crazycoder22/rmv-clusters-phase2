// ─── MyGate Visit Log ───────────────────────────────────────────────────────
// Historical audit log of visitor entries scraped from MyGate dashboard.
// Separate from the `Visitor` model (which handles live pre-approval workflow).
// Populated via `scripts/import-mygate-visitors.ts`; dedup key is `mygateId`.

model VisitLog {
  id             String    @id @default(cuid())
  mygateId       String    @unique             // MyGate transaction ID, dedup key
  visitDate      String                        // YYYY-MM-DD in IST
  visitorName    String
  visitorType    String                        // sub-type e.g. "Delivery Executive"
  fromSource     String?                       // "Swiggy", "Zomato", etc.
  block          Int?                          // null for COMMON AREA / masked
  flatNumber     String?                       // null for COMMON AREA / masked
  flatRaw        String                        // original raw "Flat" cell
  inTime         DateTime?
  outTime        DateTime?
  approvedBy         String?                   // plain string, no FK
  allowedByGuard     String?
  approvedByResident Boolean   @default(false)  // true when approvedBy differs from the guard (i.e. a real resident approval, not a guard walk-through)
  gate               String?
  status             String?                    // "In" or "Out" at scrape time
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([visitDate])
  @@index([block, flatNumber])
  @@index([fromSource])
  @@index([allowedByGuard])
  @@index([visitDate, block, flatNumber])
  @@index([visitDate, approvedByResident])
}

// ─── End MyGate Visit Log ───────────────────────────────────────────────────

// ─── Quiz Game (Kahoot-style) ───────────────────────────────────────────────

enum QuizSessionStatus {
  WAITING
  ACTIVE
  SHOWING_RESULTS
  COMPLETED
}

model Quiz {
  id          String         @id @default(cuid())
  title       String
  description String?
  createdById String
  createdBy   Resident       @relation(fields: [createdById], references: [id])
  questions   QuizQuestion[]
  sessions    QuizSession[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText  String
  options       String       // JSON: string[4]
  correctIndex  Int          // 0-3
  timeLimitSecs Int          @default(20)
  sortOrder     Int          @default(0)
  answers       QuizAnswer[]

  @@index([quizId])
}

model QuizSession {
  id                 String            @id @default(cuid())
  code               String            @unique
  quizId             String
  quiz               Quiz              @relation(fields: [quizId], references: [id])
  status             QuizSessionStatus @default(WAITING)
  currentQuestionIdx Int               @default(-1)
  questionStartedAt  DateTime?
  createdById        String
  createdBy          Resident          @relation("QuizSessionsCreated", fields: [createdById], references: [id])
  players            QuizPlayer[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status])
}

model QuizPlayer {
  id        String       @id @default(cuid())
  sessionId String
  session   QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId  String
  player    WordlePlayer @relation(fields: [playerId], references: [id])
  score     Int          @default(0)
  answers   QuizAnswer[]
  createdAt DateTime     @default(now())

  @@unique([sessionId, playerId])
  @@index([sessionId])
}

model QuizAnswer {
  id           String       @id @default(cuid())
  quizPlayerId String
  quizPlayer   QuizPlayer   @relation(fields: [quizPlayerId], references: [id], onDelete: Cascade)
  questionId   String
  question     QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerIndex  Int
  isCorrect    Boolean
  responseMs   Int
  points       Int          @default(0)
  createdAt    DateTime     @default(now())

  @@unique([quizPlayerId, questionId])
}

// ─── End Quiz Game ──────────────────────────────────────────────────────────

// ─── Medals & Virtual Coins ────────────────────────────────────────────────

enum MedalTier {
  GOLD
  SILVER
  BRONZE
}

model MedalAward {
  id          String         @id @default(cuid())
  recipientId String
  recipient   Resident       @relation("MedalsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  game        String         // "Wordle", "Tambola", or free text like "Best Diwali Decoration"
  tier        MedalTier
