// ─── Public Events ─────────────────────────────────────────────────────────
// Vendor/community events (e.g. hearing check-up camp) where anyone — not
// just logged-in residents — can register with name + block + flat + phone.
// Registrations are visible only to admins for privacy; public pages show
// only event details + the registration form.

model PublicEvent {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  title                String
  description          String?  // markdown-ish body (paragraphs)
  organizer            String?  // "Amplifon India"
  venue                String?  // "Club House - RMV Clusters Phase 2"
  startAt              DateTime
  endAt                DateTime?
  registrationClosesAt DateTime?
  active               Boolean  @default(true)
  // Optional contribution/crowdsourcing config. When contributionEnabled is
  // true, the public form collects a rupee amount from each registrant and
  // the page shows payment instructions (UPI + QR). Admins mark entries paid
  // manually after receiving the money offline.
  contributionEnabled  Boolean  @default(false)
  maxContribution      Int?     // rupees; enforced on the form if set
  targetAmount         Int?     // rupees; shown as a thermometer if set
  paymentInstructions  String?  // markdown text shown near the payment details
  paymentQrImageUrl    String?  // uploaded QR (Vercel Blob URL)
  upiId                String?  // e.g. "9019903594@okbizaxis"
  // When true, the public form collects an email from each registrant
  // (useful for events that need to follow up — e.g. TestFlight invites
  // need an Apple ID email). Optional otherwise.
  requireEmail         Boolean  @default(false)
  createdById          String
  createdBy            Resident @relation("PublicEventsCreated", fields: [createdById], references: [id])
  registrations        PublicEventRegistration[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([active])
  @@index([startAt])
}

model PublicEventRegistration {
  id                 String      @id @default(cuid())
  eventId            String
  event              PublicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name               String
  phone              String
  email              String?     // optional; required when event.requireEmail is true
  block              Int?
  flatNumber         String?
  // Contribution fields — populated only on contribution-enabled events.
  contributionAmount Int?        // rupees pledged
  paid               Boolean     @default(false)
  paidAt             DateTime?
  adminNote          String?     // optional admin note when toggling paid
  createdAt          DateTime    @default(now())

  @@index([eventId])
  @@index([phone])
}

// ─── End Public Events ─────────────────────────────────────────────────────

// ─── Vehicle Stickers ──────────────────────────────────────────────────────
// One row per flat — captures how many 4-wheeler / 2-wheeler stickers each
// flat needs for the new security agency rollout (25 May 2026 onwards).
// Public form fills this; admin reconciles for printing and pickup.
//
// `block + flatNumber` is the natural unique key — if the same flat submits
// twice we upsert (latest submission wins), so totals stay correct.

model VehicleStickerRequest {
  id            String    @id @default(cuid())
  block         Int
  flatNumber    String
  residentName  String
  phone         String
  email         String?
  residentType  String    // "OWNER" | "TENANT"
  fourWheelers  Int       @default(0)
  twoWheelers   Int       @default(0)
  notes         String?
  // Self-declared compliance flags. Set true by the resident on the form;
  // admin can override via the dashboard.
  mygateRegistered    Boolean @default(false) // resident confirms MyGate has vehicle details
  alreadyHasSticker   Boolean @default(false) // resident already collected somehow
  // Pickup tracking — set by admin once stickers are handed over, OR auto-set
  // when alreadyHasSticker=true with issuedBy="self-declared".
  stickersIssued Boolean  @default(false)
  issuedAt       DateTime?
  issuedBy       String?  // admin name, or "self-declared" for auto-issued rows
  adminNote      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([block, flatNumber], name: "block_flat")
  @@index([stickersIssued])
  @@index([mygateRegistered])
}

// ─── End Vehicle Stickers ──────────────────────────────────────────────────

// ─── Push Notification Device Tokens ───────────────────────────────────────

// Per-resident push tokens. Each resident may have several rows — one per
// device they sign in on. The token itself is unique across all rows so we
// can de-dupe when the same device is reused. `platform` is currently
// always "ios" but is here so we can fan out to Android/web later without
// a schema change.
model DeviceToken {
  id          String   @id @default(cuid())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  token       String   @unique
  platform    String   // "ios" | "android" | "web"
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([residentId])
}

// ─── End Push Notification Device Tokens ───────────────────────────────────

// ─── Habit Tracker ─────────────────────────────────────────────────────────

// Accountability-partner invite lifecycle. A habit starts at `none` (no
// partner). Inviting moves to `pending`; the partner accepts (`accepted`)
// or declines (`declined`). Only `accepted` grants view + nudge rights.
enum HabitPartnerStatus {
  none
  pending
  accepted
  declined
}

// A personal daily habit owned by one resident, with an optional
// accountability partner (another resident). Private — only the owner and
// an accepted partner can see it. Dates are stored as the midnight-IST
// instant (see src/lib/habits.ts) so the whole stack agrees on "today".
model Habit {
  id            String             @id @default(cuid())
  ownerId       String
  owner         Resident           @relation("HabitsOwned", fields: [ownerId], references: [id], onDelete: Cascade)
  title         String
  emoji         String?
  targetMinutes Int?
  startDate     DateTime
  endDate       DateTime
  active        Boolean            @default(true)
  partnerId     String?
  partner       Resident?          @relation("HabitsPartnered", fields: [partnerId], references: [id])
  partnerStatus HabitPartnerStatus @default(none)
  lastNudgedAt  DateTime?
  checkins      HabitCheckin[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([ownerId])
  @@index([partnerId])
}

// One row per completed day. `date` is the midnight-IST instant for that
// civil day; the unique constraint guarantees at most one check-in per day.
model HabitCheckin {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
}

// ─── End Habit Tracker ─────────────────────────────────────────────────────

// ─── Community Food Ordering (Home Kitchens) ────────────────────────────────

// OPEN  = accepting orders. CLOSED = chef stopped new orders (existing live).
// ARCHIVED = soft-hidden (chef "deleted" a menu that had order history; we
// keep the rows so paid/owed records survive).
enum FoodMenuStatus {
  OPEN
  CLOSED
  ARCHIVED
}

// PLACED → CONFIRMED (chef accepts / receives payment) | → CANCELLED (either).
// Payment booleans are ORTHOGONAL to this — a CANCELLED order may still carry
// buyerPaid=true (money paid, refund owed offline); never overwrite that.
enum FoodOrderStatus {
  PLACED
  CONFIRMED
  CANCELLED
}

// What a "menu" represents. KITCHEN = home-cooked food ("My Kitchen"); MARKET =
// sell-by-unit produce & goods ("Bazaar"). Same engine, kind-aware UI + copy.
enum FoodMenuKind {
  KITCHEN
  MARKET
}

// ── Parking (temporary slot sharing) ─────────────────────────────────────────

enum ParkingBookingStatus {
  BOOKED
  CANCELLED
  COMPLETED
}

// How a slot is reserved: by the hour (existing) or by the month (start date +
// optional end date; open-ended monthly blocks the slot indefinitely).
enum ParkingBookingMode {
  HOURLY
  MONTHLY
}

model ParkingSlot {
  id          String   @id @default(cuid())
  ownerId     String
  owner       Resident @relation("ParkingSlotsOwned", fields: [ownerId], references: [id], onDelete: Cascade)
  label       String                       // e.g. "Basement P2 - 45" or "Block A, Slot 12"
  location    String?                      // human directions / landmark
  description String?                      // notes: "compact cars only", etc.
  hourlyRate  Float                        // ₹ per hour
  monthlyRate Float?                       // ₹ per month (optional add-on; null = monthly not offered)
  payInfo     String?                      // owner's UPI id / phone for payment
  payQrUrl    String?                      // uploaded UPI QR image
  photoUrl    String?                      // uploaded photo of the slot (helps bookers identify it)
  active      Boolean  @default(true)      // owner can pause the listing
  bookings    ParkingBooking[]
  blocks      ParkingBlock[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@map("parking_slots")
}

model ParkingBooking {
  id                   String               @id @default(cuid())
  slotId               String
  slot                 ParkingSlot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  bookerId             String
  booker               Resident             @relation("ParkingBookingsByBooker", fields: [bookerId], references: [id])
  startAt              DateTime
  endAt                DateTime
  vehicleNumber        String?              // the car using the slot
  note                 String?
  status               ParkingBookingStatus @default(BOOKED)
  mode                 ParkingBookingMode   @default(HOURLY)
  hourlyRateSnapshot   Float?               // hourly rate captured at booking time (null for monthly)
  monthlyRateSnapshot  Float?               // monthly rate captured at booking time (null for hourly)
  openEnded            Boolean              @default(false) // monthly with no end date (endAt = far-future sentinel)
  totalAmount          Float                // rate × hours (hourly) | months × rate (monthly, informational)
  bookerPaid           Boolean              @default(false)
  bookerPaidAt         DateTime?
  ownerConfirmedPaid   Boolean              @default(false)
  ownerConfirmedPaidAt DateTime?
  cancelledBy          String?              // "booker" | "owner"
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([slotId, startAt])
  @@index([bookerId])
  @@map("parking_bookings")
}

model ParkingBlock {
  id        String      @id @default(cuid())
  slotId    String
  slot      ParkingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime    @default(now())

  @@index([slotId, startAt])
  @@map("parking_blocks")
}

model FoodMenu {
  id          String         @id @default(cuid())
  chefId      String
  chef        Resident       @relation("FoodMenusByChef", fields: [chefId], references: [id], onDelete: Cascade)
  title       String
  description String?
  date        DateTime       // midnight-IST instant for the day it's for
  orderByAt   DateTime?      // optional order deadline
  pickupInfo  String?        // e.g. "Pickup from B2-304 after 12:30"
  status      FoodMenuStatus @default(OPEN)
  kind        FoodMenuKind   @default(KITCHEN) // KITCHEN (food) | MARKET (produce/goods)
  items       FoodMenuItem[]
  orders      FoodOrder[]
  managers    FoodMenuManager[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([chefId])
  @@index([date])
  @@index([status])
  @@index([kind])
}

// A resident the owner nominated to help run a listing (edit items, manage orders).
model FoodMenuManager {
  id         String   @id @default(cuid())
  menuId     String
  menu       FoodMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident @relation("FoodMenuCoManaged", fields: [residentId], references: [id], onDelete: Cascade)
  addedById  String?  // owner who nominated (audit; plain scalar, no relation)
  createdAt  DateTime @default(now())

  @@unique([menuId, residentId])
  @@index([residentId])
}

model FoodMenuItem {
  id          String          @id @default(cuid())
  menuId      String
  menu        FoodMenu        @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float                           // per-plate (KITCHEN) | per-unit (MARKET)
  unit        String?                         // MARKET selling unit ("kg", "dozen"…); null for KITCHEN
  imageUrl    String?
  soldOut     Boolean         @default(false)
  sortOrder   Int             @default(0)
  orderItems  FoodOrderItem[]

  @@index([menuId])
}

model FoodOrder {
  id          String          @id @default(cuid())
  menuId      String
  menu        FoodMenu        @relation(fields: [menuId], references: [id], onDelete: Cascade)
  // buyerId is null for "offline" orders the chef/seller logs manually (e.g. a
  // WhatsApp/phone order from someone who doesn't use the app) — manualBuyerName
  // holds who it's for in that case.
  buyerId         String?
  buyer           Resident?   @relation("FoodOrdersByBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  manualBuyerName String?     // free-text buyer for offline/manual orders
  status      FoodOrderStatus @default(PLACED)
  note        String?
  totalAmount Float           // server-computed snapshot at order time
  buyerPaid   Boolean         @default(false) // buyer's "I paid" claim
  buyerPaidAt DateTime?
  chefPaid    Boolean         @default(false) // chef's "received" confirmation
  chefPaidAt  DateTime?
  cancelledBy String?         // "buyer" | "chef" — for dispute clarity
  items       FoodOrderItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([menuId])
  @@index([buyerId])
  @@index([status])
}

// menuItem is OPTIONAL + SetNull so deleting a dish never corrupts past order
// history — the name/price snapshots preserve exactly what was ordered.
model FoodOrderItem {
  id            String        @id @default(cuid())
  orderId       String
  order         FoodOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String?
  menuItem      FoodMenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  nameSnapshot  String
  priceSnapshot Float
  unitSnapshot  String?       // MARKET unit captured at order time ("kg"…); null for KITCHEN
  qty           Int

  @@index([orderId])
}

// Residents follow a chef to get a push when that chef publishes a new menu.
model ChefFollow {
  id         String   @id @default(cuid())
  chefId     String
  chef       Resident @relation("ChefFollowers", fields: [chefId], references: [id], onDelete: Cascade)
  followerId String
  follower   Resident @relation("ChefFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([chefId, followerId])
  @@index([chefId])
  @@index([followerId])
}

// ─── End Community Food Ordering ────────────────────────────────────────────

// ── Initiatives (structured, time-bound community feedback) ───────────────────

enum InitiativeStatus {
  OPEN
  CLOSED
  ARCHIVED
}

model Initiative {
  id              String              @id @default(cuid())
  authorId        String
  author          Resident            @relation("InitiativesAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  title           String
  body            String
  imageUrl        String?
  youtubeUrl      String?
  attachments     Json                @default("[]") // [{ url, name }] — supporting PDF documents
  status          InitiativeStatus    @default(OPEN)
  commentsCloseAt DateTime
  comments        InitiativeComment[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([authorId])
  @@map("initiatives")
}

model InitiativeComment {
  id           String                  @id @default(cuid())
  initiativeId String
  initiative   Initiative              @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  authorId     String
  author       Resident                @relation("InitiativeCommentsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       InitiativeComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      InitiativeComment[]     @relation("CommentReplies")
  content      String
  isOfficial   Boolean                 @default(false)
  likes        InitiativeCommentLike[]
  createdAt    DateTime                @default(now())

  @@index([initiativeId, parentId])
  @@index([parentId])
  @@map("initiative_comments")
}

model InitiativeCommentLike {
  id         String            @id @default(cuid())
  commentId  String
  comment    InitiativeComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident          @relation("InitiativeCommentLikes", fields: [residentId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([commentId, residentId])
  @@index([commentId])
  @@map("initiative_comment_likes")
}

// ── Referendum (binding, secret-ballot, one-flat-one-vote) ───────────────────

enum ReferendumStatus {
  OPEN
  CLOSED
}

enum ReferendumEligibility {
  OWNERS_ONLY
  ALL_RESIDENTS
}

model Referendum {
  id          String                @id @default(cuid())
  authorId    String
  author      Resident              @relation("ReferendumsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  body        String
  imageUrl    String?
  eligibility ReferendumEligibility @default(ALL_RESIDENTS)
  status      ReferendumStatus      @default(OPEN)
  closesAt    DateTime
  closedAt    DateTime?
  closedById  String?
  options     ReferendumOption[]
  ballots     ReferendumBallot[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([authorId])
  @@map("referendums")
}

model ReferendumOption {
  id           String     @id @default(cuid())
  referendumId String
  referendum   Referendum @relation(fields: [referendumId], references: [id], onDelete: Cascade)
  text         String
  sortOrder    Int        @default(0)
  voteCount    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([referendumId])
  @@map("referendum_options")
}

model ReferendumBallot {
  id           String     @id @default(cuid())
  referendumId String
  referendum   Referendum @relation(fields: [referendumId], references: [id], onDelete: Cascade)
  residentId   String
  resident     Resident   @relation("ReferendumBallotsCast", fields: [residentId], references: [id], onDelete: Cascade)
  block        Int
  flatNumber   String
  createdAt    DateTime   @default(now())

  @@unique([referendumId, block, flatNumber])
  @@index([referendumId])
  @@map("referendum_ballots")
}

// ── Duty Checklist Tracker (recurring daily staff duties + reminders) ─────────

enum DutyReminderWave {
  MORNING
  EVENING
}

model DutyChecklist {
  id           String               @id @default(cuid())
  title        String
  description  String?
  reminderWave DutyReminderWave     @default(MORNING)
  active       Boolean              @default(true)
  createdById  String
  createdBy    Resident             @relation("DutyChecklistsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  items        DutyChecklistItem[]
  owners       DutyChecklistOwner[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([active])
  @@map("duty_checklists")
}

model DutyChecklistItem {
  id          String           @id @default(cuid())
  checklistId String
  checklist   DutyChecklist    @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  title       String
  sortOrder   Int              @default(0)
  active      Boolean          @default(true)
  completions DutyCompletion[]
  createdAt   DateTime         @default(now())

  @@index([checklistId])
  @@map("duty_checklist_items")
}

model DutyChecklistOwner {
  id          String        @id @default(cuid())
  checklistId String
  checklist   DutyChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  residentId  String
  resident    Resident      @relation("DutyChecklistsOwned", fields: [residentId], references: [id], onDelete: Cascade)

  @@unique([checklistId, residentId])
  @@index([residentId])
  @@map("duty_checklist_owners")
}

model DutyCompletion {
  id         String            @id @default(cuid())
  itemId     String
  item       DutyChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  date       String
  residentId String
  resident   Resident          @relation("DutyCompletions", fields: [residentId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([itemId, date])
  @@index([itemId, date])
  @@map("duty_completions")
}

// ── Direct Messaging (private 1:1 resident chat) ─────────────────────────────

model Conversation {
  id            String          @id @default(cuid())
  aId           String                              // always the lexicographically-smaller resident id
  a             Resident        @relation("ConvA", fields: [aId], references: [id], onDelete: Cascade)
  bId           String
  b             Resident        @relation("ConvB", fields: [bId], references: [id], onDelete: Cascade)
  messages      DirectMessage[]
  lastMessageAt DateTime        @default(now())
  aLastReadAt   DateTime?
  bLastReadAt   DateTime?
  aHiddenAt     DateTime?
  bHiddenAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([aId, bId])
  @@index([aId, lastMessageAt])
  @@index([bId, lastMessageAt])
  @@map("conversations")
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         Resident     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("direct_messages")
}

// ── Sports Groups + Recurring Polls ──────────────────────────────────────────

enum GroupMemberRole {
  ORGANIZER
  MEMBER
}

enum GroupPollStatus {
  OPEN
  CLOSED
}

enum GroupPollOutcome {
  GAME_ON
  CANCELLED
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  createdById String
  createdBy   Resident      @relation("GroupsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  members     GroupMember[]
  polls       GroupPoll[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([createdAt])
  @@map("groups")
}

model GroupMember {
  id         String          @id @default(cuid())
  groupId    String
  group      Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident        @relation("GroupMemberships", fields: [residentId], references: [id], onDelete: Cascade)
  role       GroupMemberRole @default(MEMBER)
  joinedAt   DateTime        @default(now())

  @@unique([groupId, residentId])
  @@index([residentId])
  @@map("group_members")
}

model GroupPoll {
  id        String            @id @default(cuid())
  groupId   String
  group     Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  authorId  String
  author    Resident          @relation("GroupPollsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  playAt    DateTime?
  closesAt  DateTime?
  status    GroupPollStatus   @default(OPEN)
  outcome   GroupPollOutcome?
  closeNote String?
  closedAt  DateTime?
  options   GroupPollOption[]
  votes     GroupPollVote[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([groupId, createdAt])
  @@map("group_polls")
}

model GroupPollOption {
  id        String          @id @default(cuid())
  pollId    String
  poll      GroupPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int             @default(0)
  votes     GroupPollVote[]
  createdAt DateTime        @default(now())

  @@index([pollId])
  @@map("group_poll_options")
}

model GroupPollVote {
  id         String          @id @default(cuid())
  pollId     String
  poll       GroupPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId   String
  option     GroupPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident        @relation("GroupPollVotes", fields: [residentId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([pollId, residentId])
  @@index([pollId])
  @@index([optionId])
  @@map("group_poll_votes")
}

// ── SOS Panic Alerts (mobile panic button → warrior broadcast) ───────────────

enum SosAlertStatus {
  ACTIVE
  RESOLVED
}

model SosAlert {
  id           String         @id @default(cuid())
  senderId     String
  sender       Resident       @relation("SosAlertsSent", fields: [senderId], references: [id], onDelete: Cascade)
  senderName   String
  senderBlock  Int
  senderFlat   String
  senderPhone  String
  note         String?
  status       SosAlertStatus @default(ACTIVE)
  resolvedAt   DateTime?
  resolvedById String?
  responses    SosResponse[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([senderId, status])
  @@map("sos_alerts")
}

model SosResponse {
  id          String   @id @default(cuid())
  alertId     String
  alert       SosAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  responderId String
  responder   Resident @relation("SosResponses", fields: [responderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([alertId, responderId])
  @@index([alertId])
  @@map("sos_responses")
}

enum AmenityBookingStatus {
  PENDING    // awaiting admin approval (only for approval-required amenities)
  CONFIRMED  // reserved
  CANCELLED  // cancelled by booker
  REJECTED   // declined by admin
  COMPLETED  // slot has passed
}

// A bookable shared facility (clubhouse, court, gym, pool…). Admin-managed.
model Amenity {
  id                String          @id @default(cuid())
  name              String
  description       String?
  location          String?                         // human directions / landmark
  icon              String?                          // lucide icon name for the mobile UI
  capacity          Int             @default(1)      // concurrent bookings per slot (1 = exclusive)
  requiresApproval  Boolean         @default(false)  // PENDING until an admin confirms
  fee               Float           @default(0)      // ₹ per booking (0 = free)
  feeNote           String?                          // e.g. "₹500 refundable deposit"
  payInfo           String?                          // UPI id / phone for the fee
  payQrUrl          String?                          // uploaded UPI QR image
  maxPerResident    Int?                             // cap of active/future bookings per resident (null = unlimited)
  bookingWindowDays Int             @default(30)     // how far ahead residents may book
  active            Boolean         @default(true)
  slots             AmenitySlot[]
  bookings          AmenityBooking[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([active])
  @@map("amenities")
}

// A recurring bookable window template for an amenity. dayOfWeek null = every day.
// Times are minutes-from-midnight in IST (e.g. 360 = 06:00, 420 = 07:00).
model AmenitySlot {
  id          String           @id @default(cuid())
  amenityId   String
  amenity     Amenity          @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  label       String?                              // e.g. "Morning", "Full day"
  dayOfWeek   Int?                                 // 0=Sun … 6=Sat; null = applies every day
  startMinute Int                                  // minutes from IST midnight
  endMinute   Int
  bookings    AmenityBooking[]
  createdAt   DateTime         @default(now())

  @@index([amenityId])
  @@map("amenity_slots")
}

model AmenityBooking {
  id                   String               @id @default(cuid())
  amenityId            String
  amenity              Amenity              @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  slotId               String
  slot                 AmenitySlot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  bookerId             String
  booker               Resident             @relation("AmenityBookingsByBooker", fields: [bookerId], references: [id], onDelete: Cascade)
  startAt              DateTime             // concrete IST instant resolved from date + slot
  endAt                DateTime
  status               AmenityBookingStatus @default(CONFIRMED)
  feeSnapshot          Float                @default(0)   // fee captured at booking time
  note                 String?
  bookerPaid           Boolean              @default(false)
  bookerPaidAt         DateTime?
  adminConfirmedPaid   Boolean              @default(false)
  adminConfirmedPaidAt DateTime?
  approvedById         String?              // admin who approved/rejected
  approvedAt           DateTime?
  cancelledBy          String?              // "booker" | "admin"
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([amenityId, startAt])
  @@index([slotId, startAt])
  @@index([bookerId, status])
  @@index([status, startAt])
  @@map("amenity_bookings")
}

// Read-only mirror of MyGate Help Desk complaints, imported from the official
// "Download Report" export. Not linked to Resident (createdBy/flat are snapshot
// strings); status kept as a raw string since this just mirrors MyGate.
model MygateComplaint {
  id                String    @id @default(cuid())
  mygateId          String    @unique          // MyGate ticket id — dedup key for re-imports
  subject           String
  category          String?
  subCategory       String?
  type              String?                     // "personal" | "common"
  block             Int?                        // parsed from flat (e.g. "3-105" → 3)
  flatNumber        String?                     // parsed flat ("105", "310/311")
  flatRaw           String?                     // original "3-310/311"
  createdBy         String?                     // resident name (snapshot)
  status            String                      // raw MyGate status
  isOpen            Boolean   @default(true)    // derived: not Resolved/Closed
  assignee          String?
  updatedUser       String?
  escalationLevel   String?
  comments          String?
  mygateCreatedAt   DateTime?                   // MyGate "Created Date"
  lastUpdateAt      DateTime?
  closedAt          DateTime?                   // MyGate "Closed Time"
  resolutionMinutes Int?                        // parsed from "Resolution Tat"
  onHoldMinutes     Int?
  reopenCount       Int       @default(0)
  rating            Int?
  raw               Json                        // full original row
  importedAt        DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([block])
  @@index([mygateCreatedAt])
  @@map("mygate_complaints")
}
