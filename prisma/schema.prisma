// ─── MyGate Visit Log ───────────────────────────────────────────────────────
// Historical audit log of visitor entries scraped from MyGate dashboard.
// Separate from the `Visitor` model (which handles live pre-approval workflow).
// Populated via `scripts/import-mygate-visitors.ts`; dedup key is `mygateId`.

model VisitLog {
  id             String    @id @default(cuid())
  mygateId       String    @unique             // MyGate transaction ID, dedup key
  visitDate      String                        // YYYY-MM-DD in IST
  visitorName    String
  visitorType    String                        // sub-type e.g. "Delivery Executive"
  fromSource     String?                       // "Swiggy", "Zomato", etc.
  block          Int?                          // null for COMMON AREA / masked
  flatNumber     String?                       // null for COMMON AREA / masked
  flatRaw        String                        // original raw "Flat" cell
  inTime         DateTime?
  outTime        DateTime?
  approvedBy         String?                   // plain string, no FK
  allowedByGuard     String?
  approvedByResident Boolean   @default(false)  // true when approvedBy differs from the guard (i.e. a real resident approval, not a guard walk-through)
  gate               String?
  status             String?                    // "In" or "Out" at scrape time
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([visitDate])
  @@index([block, flatNumber])
  @@index([fromSource])
  @@index([allowedByGuard])
  @@index([visitDate, block, flatNumber])
  @@index([visitDate, approvedByResident])
}

// ─── End MyGate Visit Log ───────────────────────────────────────────────────

