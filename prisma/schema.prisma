  name         String
  phone        String
  categories   String[]             // e.g. ["MAID", "COOK"]
  description  String?
  availability String?              // e.g. "Mon-Sat, 8am-6pm"
  addedById    String
  addedBy      Resident             @relation("DomesticHelpAdded", fields: [addedById], references: [id])
