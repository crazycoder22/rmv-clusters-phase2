  highestTile Int          // 2, 4, 8, ..., 2048, 4096, ...
  moves       Int
  duration    Int          // seconds
  won         Boolean      @default(false) // reached 2048
  createdAt   DateTime     @default(now())

  @@index([playerId])
  @@index([score])
  @@index([createdAt])
}

