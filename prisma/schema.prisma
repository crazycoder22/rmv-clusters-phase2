  session       TambolaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId      String
  player        WordlePlayer   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  ticket        String         // JSON: number[][] (3×9 grid, 0 for blank)
