// ─── Tambola Game ────────────────────────────────────────────────────────────

enum TambolaSessionStatus {
  WAITING
  ACTIVE
  COMPLETED
}

enum TambolaPrizeType {
  EARLY_FIVE
  TOP_LINE
  MIDDLE_LINE
  BOTTOM_LINE
  FULL_HOUSE
}

model TambolaSession {
  id           String               @id @default(cuid())
  code         String               @unique
  title        String
  status       TambolaSessionStatus @default(WAITING)
  drawnNumbers String               @default("[]") // JSON array of drawn numbers
  createdById  String
  createdBy    Resident             @relation(fields: [createdById], references: [id])
