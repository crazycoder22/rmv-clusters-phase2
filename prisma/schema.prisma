  @@index([avgRating])
}

model DomesticHelpReview {
  id             String       @id @default(cuid())
  domesticHelpId String
  domesticHelp   DomesticHelp @relation(fields: [domesticHelpId], references: [id], onDelete: Cascade)
  residentId     String
  resident       Resident     @relation("DomesticHelpReviews", fields: [residentId], references: [id], onDelete: Cascade)
  rating         Int          // 1-5
  comment        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([domesticHelpId, residentId])
  @@index([domesticHelpId])
  @@index([residentId])
}

// ─── End Domestic Help Directory ──────────────────────────────────────────

// ─── Food Vendors (external vendors, WhatsApp ordering) ───────────────────

model FoodVendor {
  id           String           @id @default(cuid())
  name         String
  phone        String                              // WhatsApp / call number
  description  String?
  notes        String?                             // freeform: "Veg sold by weight, min ½ kg"
  deliveryInfo String?                             // e.g. "Delivery 10am–1pm"
  photoUrl     String?
  forDate      DateTime?                           // optional: a dated special menu
  active       Boolean          @default(true)
  addedById    String
  addedBy      Resident         @relation("FoodVendorsAdded", fields: [addedById], references: [id])
  items        FoodVendorItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([addedById])
  @@index([active])
}

model FoodVendorItem {
  id        String     @id @default(cuid())
  vendorId  String
  vendor    FoodVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name      String
  price     Float
  unit      String?                                // MARKET_UNITS value (kg/piece/…); null = flat ₹
  section   String?                                // "Veg" | "Non-veg" | "Sweets" | …
  note      String?                                // "25 pieces", etc.
  sortOrder Int        @default(0)

  @@index([vendorId])
}

// ─── End Food Vendors ─────────────────────────────────────────────────────

// ─── Marketplace ──────────────────────────────────────────────────────────

model MarketplaceListing {
  id              String                @id @default(cuid())
  title           String
  description     String
  images          String[]              // Vercel Blob URLs
  category        String                // "FURNITURE", "ELECTRONICS", etc.
  listingType     String                // "SELL", "GIVEAWAY", "RENT"
  price           Float                 @default(0)
  rentPeriod      String?               // "DAY", "WEEK", "MONTH" — for RENT type
  status          String                @default("ACTIVE") // "ACTIVE", "SOLD"
  whatsappNumber  String
  sellerId        String
  seller          Resident              @relation("MarketplaceListings", fields: [sellerId], references: [id], onDelete: Cascade)
