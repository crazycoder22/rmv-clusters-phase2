# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
prisma/dev.db
prisma/dev.db-journal

# mobile (Capacitor)
/mobile/node_modules
/mobile/dist
/mobile/.env*

# Native iOS — track sources (Info.plist, icons, project files), ignore
# generated build output. Cocoapods is not used (Capacitor 8 uses SPM).
/mobile/ios/App/build
/mobile/ios/App/Pods
/mobile/ios/App/App/public
/mobile/ios/DerivedData
/mobile/ios/.build
/mobile/ios/**/xcuserdata/

# Native Android — same idea, track sources, drop build output.
/mobile/android/.gradle
/mobile/android/build
/mobile/android/app/build
/mobile/android/local.properties
/mobile/android/.idea
/mobile/android/app/release

# Release signing — secrets, never commit
/mobile/android/keystore.properties
/mobile/android/**/*.keystore
/mobile/android/**/*.jks

# ─── Local data dumps — resident PII, NEVER commit ──────────────────────────
# Root-level spreadsheets / CSV exports + scratch DB used during ops work.
/*.csv
/*.xlsx
/*.xls
/dev.db
/dev.db-journal
/photos/
/SVB-QR.jpeg
/rmv-side-view.webp

# Stray root-level Capacitor init — the real app lives in /mobile.
/ios/

# Local editor / agent tooling
/.claude/
/.vscode/
/.idea/

# MyGate report data (resident PII — never commit)
scripts/.data/
